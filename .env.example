# IdeaL server configuration. Copy to `.env` and edit. NEVER commit `.env`.

# Shared bearer token — REQUIRED. Anyone with this token can read AND write the
# store, so make it long and random (e.g. `openssl rand -hex 32`).
IDEAL_TOKEN=change-me-to-a-long-random-secret

# Port the server listens on (host:container). OPEN THIS in your VM firewall /
# security group so the machine running Claude Code can reach it.
IDEAL_PORT=8000

# Interface the server binds to. Default 0.0.0.0 (all interfaces). Set to
# 127.0.0.1 to bind loopback-only — e.g. when fronting with a reverse proxy or
# reaching it via the SSH tunnel. Honored on the direct run.sh path; under Docker
# the container always binds 0.0.0.0 internally and reachability is governed by
# IDEAL_PORT publishing.
IDEAL_HOST=0.0.0.0

# Where the SQLite file lives INSIDE the container. It is persisted to ./data on
# the host via the compose volume, so it survives restarts and rebuilds.
IDEAL_DB_PATH=/data/ideal.sqlite

# Require the bearer token on read endpoints too (recommended: true). /export
# dumps the entire store, so protecting reads is sensible.
IDEAL_PROTECT_READS=true

# What to do when a new idea references a link target that does not exist:
#   reject  -> refuse the whole request (recommended; keeps the graph honest)
#   ignore  -> create the idea, silently drop the bad edges
IDEAL_ON_UNKNOWN_TARGET=reject

# --- Optional server-side semantic search (POST /search) ---------------------
# When true, the server embeds each idea on write and answers semantic queries
# (/ideal-search). This pulls a CPU torch wheel (~1-2 GB image, a few hundred MB
# RAM for the warm model); the model is cached on the ./data volume, downloaded
# once. Set to false for a lightweight deploy — /search then returns 503 and the
# core store/export flow is unaffected.
IDEAL_RAG_ENABLED=true

# sentence-transformers model used for embeddings. Changing it re-embeds the
# whole store on next boot (vectors are keyed by model; a different model's are
# ignored and rebuilt). Default is arctic-embed-s: asymmetric (its query prompt is
# applied only on the search side), 384-dim like MiniLM, ~130 MB. For the older,
# slightly-lighter symmetric baseline set IDEAL_RAG_MODEL=all-MiniLM-L6-v2.
IDEAL_RAG_MODEL=Snowflake/snowflake-arctic-embed-s
